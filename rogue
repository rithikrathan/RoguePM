#!/bin/bash

# ==========================================
# GLOBAL CONFIGURATIONS
# ==========================================
CONFIG_FILE="$HOME/.roguerc"
PROJECTS_DIR="$HOME/Desktop/projects"
TEMPLATES_DIR="$HOME/Desktop/projects/RoguePM/RogueTemplates"
LOCAL_PROJECTS_LIST="$HOME/Desktop/projects/RoguePM/rp.list"
# Source config file if it exists to override defaults
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

# ==========================================
# UTILITY FUNCTIONS
# ==========================================
# ==========================================
# UTILITY FUNCTIONS
# ==========================================
log_info() {
    echo -e "\e[1;3;31m[Rogue]\e[0m  $1"
}

log_error() {
    echo -e "\e[1;3;31m[Rogue]  Error: $1\e[0m" >&2
}
print_banner() {
    cat << "EOF"
  ____                                  ____   __  __ 
 |  _ \  ___    __ _  _   _  ___       |  _ \ |  \/  |
 | |_) |/ _ \  / _` || | | | / _ \     | |_) || |\/| |
 |  _ <| (_) || (_| || |_| ||  __/     |  __/ | |  | |
 |_| \_\\___/  \__, | \__,_| \___|_____|_|    |_|  |_|
               |___/             |_____|
EOF
}

print_help() {
    echo -e "\n\e[1mUsage:\e[0m source rogue <mode> [options]"
    echo -e "\n\e[1mModes:\e[0m"
    echo -e "  new          Create a new project (run 'rogue new --help' for options)"
    echo -e "  snapshot     Push changes from all projects in the projects directory"
    echo -e "  open         Open a project directory using fzf/rofi (run 'rogue open --help' for options)"
    echo -e "  setPat       Embeds \$GHPAT from your environment into the git remote URL"
    echo -e "  addRemote    Creates and adds a GitHub remote for the current local repository"
    echo -e "  help         Show this general help message\n"
}

# ==========================================
# COMMAND: SNAPSHOT
# ==========================================
cmd_snapshot() {
    echo -e "\n[~~~~~~~~~~~~~~~~~~~~|Pushing snapshots of your projects|~~~~~~~~~~~~~~~~~~]"
    
    for dir in "$PROJECTS_DIR"/*; do
        [ ! -d "$dir" ] && continue 

        local dirBaseName=$(basename "$dir")
        echo -e "\n\e[1;3;31m[Rogue]\e[0m Opening $dirBaseName."
        
        if [ -d "$dir/.git" ]; then
            log_info "Git repository found, proceeding....."
            cd "$dir" || continue
            
            if ! git diff --quiet || ! git diff --cached --quiet; then
                log_info "Commiting changes in $dirBaseName"
                git add -A
                git commit -m "RoguePM: Project snapshot"
                local branch=$(git symbolic-ref --short HEAD)
                log_info "Pushing to $branch branch. \n"
                git push origin "$branch"
            else
                log_info "No changes, $dirBaseName is up to date, skipping..... "
            fi
        else
            log_info "Git repository not found, skipping....."
        fi
        echo "-----------------------------------------------------------------------------"
    done
    
    echo -e "\n\e[1;3;31m[Rogue]\e[0m Finished checking all project directories"
    log_info "Exiting......"
}

# ==========================================
# COMMAND: NEW
# ==========================================
cmd_new() {
    local replace="false"
    local create_local="false"
    local create_remote="false"
    local project_name=""
    local visibility="private"
    local commit_msg="Initial commit"
    local desc_msg="This is a default description message generated by RoguePM and will be changed in the future"
    local license="mit"
    local template="default"
    local include_license="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -r|--replace) replace="true"; shift ;;
            --local) create_local="true"; shift ;;
            --remote) create_remote="true"; shift ;;
            -v|--visibility) 
                if [[ "$2" != "public" && "$2" != "private" ]]; then
                    log_error "Visibility must be 'public' or 'private'."
                    return 1
                fi
                visibility="$2"
                shift 2 ;;
            -t|--template) 
                if [[ -z "$2" ]];then
                    log_error "Template name cannot be empty."
                    return 1
                fi
                if [[ -d "$TEMPLATES_DIR/$2" ]]; then
                    template="$2"
                else
                    log_error "Template does not exist. Using default template."
                    template="default"
                fi
                shift 2 ;;
            -m|--message) 
                [ -z "$2" ] && { log_error "Commit message cannot be empty."; return 1; }
                commit_msg="$2"
                shift 2 ;;
            -d|--description) 
                [ -z "$2" ] && { log_error "Description cannot be empty."; return 1; }
                desc_msg="$2"
                shift 2 ;;
            -l|--license) 
                include_license="true"
                if [[ -z "$2" || "$2" == -* ]]; then
                    license="mit"
                    shift 1
                else
                    license="$2"
                    shift 2
                fi ;;
            --help|-h)
                echo -e "\n\e[1mUsage:\e[0m source rogue new [project_name] [options]"
                echo -e "  -r                 Replace existing directory if it exists"
                echo -e "  --local            Create project in current working directory instead of $PROJECTS_DIR"
                echo -e "  --remote           Create and push to a new GitHub repository"
                echo -e "  -v <pub|priv>      Set repository visibility (default is private)"
                echo -e "  -t <template>      Use a specific project template"
                echo -e "  -m <message>       Initial commit message"
                echo -e "  -d <description>   Project description for GitHub repo"
                echo -e "  -l [license]       Add license file using GitHub CLI (default: mit)"
                return 0 ;;
            *)
                if [[ -z "$project_name" && "$1" != -* ]]; then
                    project_name="$1"
                else
                    log_error "Invalid flag for 'new': $1"
                    return 1
                fi
                shift ;;
        esac
    done

    if [ -z "$project_name" ]; then
        read -p $'\e[1;3;31m[Rogue]\e[0m Enter project name: ' project_name
    fi

    # ==========================================
    # PRE-FLIGHT CHECK: Network & Auth
    # ==========================================
    local github_user=""
    if [ "$create_remote" == "true" ]; then
        echo -e "\n[~~~~~~~~~~~~~~~~~|Checking GitHub Connectivity|~~~~~~~~~~~~~~~~~]"
        
        if ! github_user=$(gh api user --jq .login 2>/dev/null); then
            log_error "Cannot reach GitHub or GitHub CLI is not authenticated."
            read -p $'\e[1;3;31m[Rogue]\e[0m Continue with local folder setup only? (y/n): ' fallback_choice
            
            if [[ "$fallback_choice" =~ ^[Yy]$ ]]; then
                log_info "Proceeding with local setup. (Skipping remote creation)"
                create_remote="false"
            else
                log_info "Aborting project creation safely. No files were created."
                return 1
            fi
        else
            log_info "GitHub is reachable. Logged in as: $github_user"
        fi
    fi

    echo -e "\n[~~~~~~~~~~~~~~~~~~|Creating project directory|~~~~~~~~~~~~~~~~]"

    if [ "$create_local" == "true" ]; then
        local target_dir="$PWD/$project_name"
        echo "$target_dir" >> "$LOCAL_PROJECTS_LIST"
        awk '!seen[$0]++' "$LOCAL_PROJECTS_LIST" > "${LOCAL_PROJECTS_LIST}.tmp" && mv "${LOCAL_PROJECTS_LIST}.tmp" "$LOCAL_PROJECTS_LIST"
    else
        local target_dir="$PROJECTS_DIR/$project_name"
    fi

    if [ -d "$target_dir" ]; then
        if [ "$replace" == "true" ]; then
            log_info "Replacing existing directory....."
            rm -rf "$target_dir"
            mkdir -p "$target_dir"
        else
            log_error "Directory already exists! Try again with -r flag to replace it."
            return 1
        fi
    else
        log_info "Creating project directory....."
        mkdir -p "$target_dir"
    fi
    
    log_info "Current directory is set to $target_dir"
    cd "$target_dir" || return 1

    echo -e "\n[~~~~~~~~~~~~~~~~~|Initializing Version Control|~~~~~~~~~~~~~~~~~]"
    git init

    if [ "$create_remote" == "true" ]; then
        gh repo create "$project_name" --"$visibility" --source=. --remote=origin --description "$desc_msg"
        log_info "GitHub repository created: https://github.com/$github_user/$project_name"
    fi

    echo -e "\n[~~~~~~~~~~~~~~~|Creating Basic files and folders|~~~~~~~~~~~~~]"
    log_info "Using '$template' template......"
    local template_script="$TEMPLATES_DIR/$template/$template.sh"
    
    if [ -x "$template_script" ]; then
        "$template_script" -n "$project_name" -l "$license" -m "$commit_msg"
    else
        log_error "Template script not found or not executable at: $template_script"
    fi

    echo -e "\n[~~~~~~~~~~~~~~~~~~~~|Making initial commit|~~~~~~~~~~~~~~~~~~~]"
    git add .
    git commit -m "$commit_msg"

    if [ "$create_remote" == "true" ]; then
        echo -e "\n[~~~~~~~~~~~~~~~~~~~~|Pushing to \e[1mMaster\e[0m branch|~~~~~~~~~~~~~~~~~~]"
        git push -u origin master
    fi
    
    log_info "Finished creating project: $project_name"
}

# ==========================================
# COMMAND: ADD REMOTE
# ==========================================
cmd_addRemote() {
    local visibility="private"
    local desc_msg="Repository created via RoguePM"
    local project_name=$(basename "$PWD")

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--visibility) 
                if [[ "$2" != "public" && "$2" != "private" ]]; then
                    log_error "Visibility must be 'public' or 'private'."
                    return 1
                fi
                visibility="$2"
                shift 2 ;;
            -d|--description) 
                [ -z "$2" ] && { log_error "Description cannot be empty."; return 1; }
                desc_msg="$2"
                shift 2 ;;
            -n|--name) 
                [ -z "$2" ] && { log_error "Project name cannot be empty."; return 1; }
                project_name="$2"
                shift 2 ;;
            --help|-h)
                echo -e "\n\e[1mUsage:\e[0m source rogue addRemote [options]"
                echo -e "  -v <pub|priv>      Set repository visibility (default is private)"
                echo -e "  -d <description>   Project description for GitHub repo"
                echo -e "  -n <name>          Specific repository name (defaults to current folder name)"
                return 0 ;;
            *) log_error "Invalid flag for 'addRemote': $1"; return 1 ;;
        esac
    done

    echo -e "\n[~~~~~~~~~~~~~~~~~|Adding GitHub Remote|~~~~~~~~~~~~~~~~~]"

    if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
        log_error "You are not inside a git repository. Navigate to a project or run 'git init'."
        return 1
    fi

    # Network / Auth Pre-flight Check
    local github_user=""
    if ! github_user=$(gh api user --jq .login 2>/dev/null); then
        log_error "Cannot reach GitHub or GitHub CLI is not authenticated."
        log_info "Aborting remote creation. Ensure you have internet and have run 'gh auth login'."
        return 1
    fi

    # Check if 'origin' already exists
    if git remote get-url origin > /dev/null 2>&1; then
        log_error "A remote named 'origin' already exists for this repository."
        return 1
    fi

    log_info "Creating GitHub repository: $project_name ($visibility)..."
    gh repo create "$project_name" --"$visibility" --source=. --remote=origin --description "$desc_msg"
    log_info "GitHub repository created: https://github.com/$github_user/$project_name"

    # Push to whatever branch they are currently on
    local branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "master")
    
    echo -e "\n[~~~~~~~~~~~~~~~~~~~~|Pushing to \e[1m$branch\e[0m branch|~~~~~~~~~~~~~~~~~~]"
    git push -u origin "$branch"
}

# ==========================================
# COMMAND: SET PAT
# ==========================================
cmd_setPat() {
    echo -e "\n[~~~~~~~~~~~~~~~~~|Configuring GitHub PAT|~~~~~~~~~~~~~~~~~]"
    
    if [ -z "$GHPAT" ]; then
        log_error "\$GHPAT environment variable is not set. Please add it to your .bashrc or .zshrc."
        return 1
    fi

    if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
        log_error "You are not inside a git repository. Navigate to one and try again."
        return 1
    fi

    local remote_url
    remote_url=$(git remote get-url origin 2>/dev/null)

    if [ -z "$remote_url" ]; then
        log_error "No 'origin' remote found. Have you added a remote yet?"
        return 1
    fi

    if [[ "$remote_url" =~ ^https://(www\.)?github\.com/(.*)$ ]]; then
        local repo_path="${BASH_REMATCH[2]}"
        local new_url="https://${GHPAT}@github.com/${repo_path}"
        
        git remote set-url origin "$new_url"
        log_info "Successfully embedded \$GHPAT into the 'origin' remote URL."
    
    elif [[ "$remote_url" =~ ^https://.*@github\.com/.*$ ]]; then
        log_info "Remote URL already contains authentication. Overwriting with current \$GHPAT..."
        
        local repo_path_clean
        repo_path_clean=$(echo "$remote_url" | sed -E 's|^https://.*@github\.com/||')
        local override_url="https://${GHPAT}@github.com/${repo_path_clean}"
        
        git remote set-url origin "$override_url"
        log_info "Updated existing authentication with current \$GHPAT."
    
    else
        log_error "Remote URL is not a standard GitHub HTTPS URL (it might be SSH). URL: $remote_url"
        return 1
    fi
}

# ==========================================
# COMMAND: OPEN
# ==========================================
cmd_open() {
    local run_session="false"
    local use_gui="false"
    local open_term="false"
    local open_explorer="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -t|--terminal) run_session="true"; shift ;;
            -g|--gui) use_gui="true"; shift ;;
            --term) open_term="true"; shift ;;
            --explorer) open_explorer="true"; shift ;;
            --help|-h)
                echo -e "\n\e[1mUsage:\e[0m source rogue open [options]"
                echo -e "  -t, --terminal     Run session.sh in the selected project directory"
                echo -e "  -g, --gui          Use rofi instead of fzf for selection"
                echo -e "  --term             Open project in a new Alacritty window"
                echo -e "  --explorer         Open project in Nautilus file manager"
                return 0 ;;
            *) log_error "Invalid flag for 'open': $1"; return 1 ;;
        esac
    done

    declare -a fzf_entries
    declare -a proj_paths

    # 1. Gather projects from the main directory
    if [ -d "$PROJECTS_DIR" ]; then
        for dir in "$PROJECTS_DIR"/*; do
            if [ -d "$dir" ]; then
                proj_paths+=("$dir")
                fzf_entries+=("$(basename "$dir")  |  $dir")
            fi
        done
    fi

    # 2. Gather additional projects from rp.list
    if [ -f "$LOCAL_PROJECTS_LIST" ]; then
        while IFS= read -r dir; do
            if [ -d "$dir" ]; then
                if [[ ! " ${proj_paths[*]} " =~ " ${dir} " ]]; then
                    proj_paths+=("$dir")
                    fzf_entries+=("$(basename "$dir") [Local]  |  $dir")
                fi
            fi
        done < "$LOCAL_PROJECTS_LIST"
    fi

    if [ ${#fzf_entries[@]} -eq 0 ]; then
        log_error "No projects found."
        return 1
    fi

    # 3. Pipe to either fzf or rofi based on flags
    local selected_line
    
    if [ "$use_gui" == "true" ]; then
        if ! command -v rofi &> /dev/null; then
            log_error "'rofi' is not installed. Please install it to use the -g flag."
            return 1
        fi
        selected_line=$(printf "%s\n" "${fzf_entries[@]}" | rofi -dmenu -i -p "Rogue Open")
    else
        if ! command -v fzf &> /dev/null; then
            log_error "'fzf' is not installed. Please install it to use the open command."
            return 1
        fi
        selected_line=$(printf "%s\n" "${fzf_entries[@]}" | fzf --prompt="[Rogue] Open > " --height=40% --border=rounded --color="prompt:#ff2030,info:#40ff20,pointer:#ff2030")
    fi

    # Check if user pressed escape/Ctrl+C
    if [ -z "$selected_line" ]; then
        return 0
    fi

    # 4. Extract the path (everything after the " | ")
    local target_dir
    target_dir=$(echo "$selected_line" | awk -F ' \\|  ' '{print $2}')

    # 5. Handle Execution Flags
    if [ "$open_explorer" == "true" ]; then
        if command -v nautilus &> /dev/null; then
            log_info "Opening Nautilus..."
            nautilus "$target_dir" > /dev/null 2>&1 &
        else
            log_error "Nautilus is not installed."
        fi
    fi

    if [ "$open_term" == "true" ]; then
        if command -v alacritty &> /dev/null; then
            log_info "Opening Alacritty..."
            alacritty --working-directory "$target_dir" > /dev/null 2>&1 &
        else
            log_error "Alacritty is not installed."
        fi
    fi

    if [ "$run_session" == "true" ]; then
        if [ -f "$target_dir/session.sh" ]; then
            log_info "Executing session.sh..."
            cd "$target_dir" || return 1
            chmod +x ./session.sh
            ./session.sh
            return 0
        fi
    else
        # log_info "Entering $target_dir..."
        cd "$target_dir" || return 1
    fi
}

# ==========================================
# MAIN DISPATCHER
# ==========================================
main() {
    print_banner

    if [[ $# -eq 0 ]]; then
        print_help
        return 1
    fi

    local command="$1"
    shift

    case "$command" in
        new) cmd_new "$@" ;;
        snapshot)
            [[ $# -gt 0 ]] && { log_error "'snapshot' takes no arguments."; return 1; }
            cmd_snapshot ;;
        addRemote) cmd_addRemote "$@" ;;
        setPat)
            [[ $# -gt 0 ]] && { log_error "'setPat' takes no arguments."; return 1; }
            cmd_setPat ;;
        open) cmd_open "$@" ;;
        --help|-h|help) print_help ;;
        *)
            log_error "Unknown command: $command"
            print_help
            return 1 ;;
    esac
}

main "$@"
