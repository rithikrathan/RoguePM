#!/bin/bash

# DISPATCHER: RoguePM
# ==========================================

CONFIG_FILE="$HOME/.roguerc"
PROJECTS_DIR="/mnt/sda4/projects"
TEMPLATES_DIR="/mnt/sda4/projects/RoguePM/RogueTemplates"
LOCAL_PROJECTS_LIST="/mnt/sda4/projects/RoguePM/rp.list"
DEFAULT_REMOTE="github"
TERMINAL_APP="alacritty"
FILE_MANAGER="dolphin"

readonly VERSION="1.1.1"
if [ -n "$BASH_SOURCE" ]; then
    ROGUE_SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null)"
elif [ -n "$ZSH_VERSION" ]; then
    ROGUE_SCRIPT_PATH="$(realpath "$0" 2>/dev/null)"
fi

ROGUE_DIR="${ROGUE_SCRIPT_PATH:+$(dirname "$ROGUE_SCRIPT_PATH")}"

# Style definitions
ROGUE_RED_ITALIC="\e[1;3;31m"
ROGUE_RED_SOLID="\e[1;31m"
GREEN="\e[32m"
YELLOW="\e[33m"
CYAN="\e[36m"
GRAY="\e[90m"
RESET="\e[0m"
BOLD="\e[1m"
BOLD_ITALIC_UNDERLINE="\e[1;3;4m"
ROSE_PINE_GOLD="\e[38;2;246;193;119m"

log_info() {
    echo -e "${ROGUE_RED_ITALIC}[Rogue]${RESET} $1"
}

log_success() {
    echo -e "${ROGUE_RED_ITALIC}[Rogue]${RESET} ${GREEN}$1${RESET}"
}

log_error() {
    echo -e "${ROGUE_RED_ITALIC}[Rogue]${RESET} ${YELLOW}Error:${RESET} $1" >&2
}

log_prompt() {
    read -p $'\e[1;3;31m[Rogue]\e[0m '"$1" "$2"
}

log_divider() {
    echo -e "\n${BOLD}$1${RESET}"
}

print_banner() {
    echo -e "${ROGUE_RED_SOLID}"
    cat << "EOF"
'||'''|,                                   '||'''|, '||\   /||` 
 ||   ||                                    ||   ||  ||\\.//||  
 ||...|' .|''|, .|''|, '||  ||` .|''|,      ||...|'  ||     ||  
 || \\   ||  || ||  ||  ||  ||  ||..||      ||       ||     ||  
.||  \\. `|..|' `|..||  `|..'|. `|...      .||      .||     ||. 
                    ||              .\\\\\'                     
                 `..|'                                          
EOF
    echo -e "${RESET}"
}

print_divider() {
    echo -e "${ROGUE_RED_SOLID}>=-=-=-=-=-=-=-=[ ${BOLD}*${ROGUE_RED_SOLID} ]=-=-=-=-=-=-=-=<${RESET}"
}

log_step() {
    echo -e "  ${ROGUE_RED_SOLID}◆${RESET} $1"
}

print_help() {
    echo -e "\n${ROGUE_RED_ITALIC}[Rogue]${RESET} ${BOLD}COMMAND MENU${RESET}"
    echo -e "Usage: source rogue <mode> [options]\n"
    echo -e "  ${BOLD}new${RESET}          Create a new project (run 'rogue new --help')"
    echo -e "  ${BOLD}snapshot${RESET}     Push changes from all projects to ALL configured remotes"
    echo -e "  ${BOLD}template${RESET}     List templates or view template file tree"
    echo -e "  ${BOLD}list${RESET}         List all projects with branch, status, and last commit"
    echo -e "  ${BOLD}open${RESET}         Open a project directory using fzf/rofi"
    echo -e "  ${BOLD}daemon${RESET}       Talk to the rogued background daemon"
    echo -e "  ${BOLD}setPat${RESET}       Embeds \$GHPAT/\$GLPAT into all HTTPS git remote URLs"
    echo -e "  ${BOLD}addRemote${RESET}    Creates and adds a specified remote (github/gitlab)"
    echo -e "  ${BOLD}setup${RESET}        Install RoguePM to ~/.local/bin and ~/.config/rogue"
    echo -e "  ${BOLD}update${RESET}       Pull latest from git repo and reinstall"
    echo -e "  ${BOLD}help${RESET}         Show this general help message\n"
}

# ==========================================
# JSON CONFIG LOADER
# ==========================================

read_json_config() {
    local json_file="$HOME/.config/rogue/rogueConf.json"
    [ ! -f "$json_file" ] && return

    if ! command -v jq &> /dev/null; then
        log_error "jq is required for JSON config (rogueConf.json). Install it or remove $json_file"
        return 1
    fi

    local value

    value=$(jq -r '.projects_dir // empty' "$json_file" 2>/dev/null)
    [ -n "$value" ] && PROJECTS_DIR="${value/#\~/$HOME}"

    value=$(jq -r '.templates_dir // empty' "$json_file" 2>/dev/null)
    [ -n "$value" ] && TEMPLATES_DIR="${value/#\~/$HOME}"

    value=$(jq -r '.local_projects_list // empty' "$json_file" 2>/dev/null)
    [ -n "$value" ] && LOCAL_PROJECTS_LIST="${value/#\~/$HOME}"

    value=$(jq -r '.config_file // empty' "$json_file" 2>/dev/null)
    [ -n "$value" ] && CONFIG_FILE="${value/#\~/$HOME}"

    value=$(jq -r '.default_remote // empty' "$json_file" 2>/dev/null)
    [ -n "$value" ] && DEFAULT_REMOTE="$value"

    value=$(jq -r '.terminal_app // empty' "$json_file" 2>/dev/null)
    [ -n "$value" ] && TERMINAL_APP="$value"

    value=$(jq -r '.file_manager // empty' "$json_file" 2>/dev/null)
    [ -n "$value" ] && FILE_MANAGER="$value"
}

read_json_config

if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

# ==========================================
# MODULE LOADER
# ==========================================

load_modules() {
    local modules_dir=""
    if [ -d "$ROGUE_DIR/modules" ]; then
        modules_dir="$ROGUE_DIR/modules"
    elif [ -d "$HOME/.config/rogue/modules" ]; then
        modules_dir="$HOME/.config/rogue/modules"
    else
        log_error "Modules directory not found. Run 'rogue setup' to install."
        return 1
    fi

    local loaded=0
    for m in "$modules_dir"/*.sh; do
        if [ -f "$m" ]; then
            source "$m"
            ((loaded++))
        fi
    done

    if [ "$loaded" -eq 0 ]; then
        log_error "No modules found in $modules_dir"
        return 1
    fi
}

load_modules

# ==========================================
# COMMAND: SETUP
# ==========================================

cmd_setup() {
    local force="false"
    local remove="false"
    local sym="false"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force="true"; shift ;;
            --remove) remove="true"; shift ;;
            --sym) sym="true"; shift ;;
            --help|-h)
                echo -e "\n${ROGUE_RED_ITALIC}[Rogue]${RESET} ${BOLD}SETUP COMMAND USAGE${RESET}"
                echo -e "source rogue setup [options]\n"
                echo -e "  --force        Overwrite existing installation"
                echo -e "  --remove       Remove RoguePM setup (clean all installed files)"
                echo -e "  --sym          Symlink instead of copy (points to repo)"
                echo -e "  --help, -h     Show this help message\n"
                echo -e "Installs RoguePM to:"
                echo -e "  ~/.local/bin/rogue"
                echo -e "  ~/.config/rogue/modules/"
                echo -e "  ~/.config/rogue/templates/"
                echo -e "  ~/.config/rogue/rp.list"
                echo -e "  ~/.config/rogue/rogueConf.json\n"
                return 0 ;;
            *) log_error "Invalid flag for 'setup': $1"; return 1 ;;
        esac
    done

    if [ "$remove" = "true" ]; then
        echo -e "\n────────────────────────────────────────────"
        echo -e "${ROGUE_RED_ITALIC}[Rogue]${RESET} ${BOLD_ITALIC_UNDERLINE}Removing RoguePM Setup${RESET}\n"

        local removed_something="false"

        if [ -f "$HOME/.local/bin/rogue" ]; then
            rm -f "$HOME/.local/bin/rogue"
            log_step "Removed ~/.local/bin/rogue"
            removed_something="true"
        fi

        if [ -d "$HOME/.config/rogue" ]; then
            rm -rf "$HOME/.config/rogue"
            log_step "Removed ~/.config/rogue/"
            removed_something="true"
        fi

        if [ -f "$HOME/.roguerc" ]; then
            rm -f "$HOME/.roguerc"
            log_step "Removed ~/.roguerc"
            removed_something="true"
        fi

        for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.config/fish/config.fish"; do
            if [ -f "$rc" ]; then
                if grep -q "rogue()" "$rc" 2>/dev/null || grep -q "function rogue" "$rc" 2>/dev/null; then
                    sed -i '/^# RoguePM - Project Manager/,/^}/d' "$rc" 2>/dev/null
                    sed -i '/^# RoguePM - Project Manager/,/^end/d' "$rc" 2>/dev/null
                    sed -i '/^rogue() {/,/^}/d' "$rc" 2>/dev/null
                    sed -i '/^function rogue/,/^end/d' "$rc" 2>/dev/null
                    sed -i '/^[[:space:]]*$/d' "$rc" 2>/dev/null
                    log_step "Removed rogue function from $rc"
                    removed_something="true"
                fi
            fi
        done

        rm -f /tmp/.rogue_cd

        if [ "$removed_something" = "true" ]; then
            log_success "RoguePM has been completely removed."
        else
            log_step "No RoguePM installation found. Nothing to remove."
        fi
        return 0
    fi

    if [ -f "$HOME/.local/bin/rogue" ] && [ "$force" != "true" ]; then
        log_error "Rogue is already set up at ~/.local/bin/rogue"
        log_info "Run 'rogue setup --force' to overwrite"
        return 1
    fi

    if [ -z "$ROGUE_DIR" ] || [ ! -f "$ROGUE_DIR/rogue" ]; then
        log_error "Cannot detect RoguePM repository location."
        log_info "Run 'rogue setup' from the RoguePM directory."
        return 1
    fi

    if [ -f "$HOME/.config/rogue/rogueConf.json" ] && [ "$force" != "true" ]; then
        local overwrite_choice
        log_prompt "Rogue config already exists at ~/.config/rogue. Overwrite? (y/n): " overwrite_choice
        if [[ ! "$overwrite_choice" =~ ^[Yy]$ ]]; then
            log_info "Setup aborted."
            return 1
        fi
    fi

    echo -e "\n────────────────────────────────────────────"
    echo -e "${ROGUE_RED_ITALIC}[Rogue]${RESET} ${BOLD_ITALIC_UNDERLINE}Installing RoguePM${RESET}\n"

    mkdir -p "$HOME/.local/bin" "$HOME/.config/rogue/modules" "$HOME/.config/rogue/templates"

    if [ "$sym" = "true" ]; then
        log_step "Symlinking rogue script..."
        ln -sf "$ROGUE_DIR/rogue" "$HOME/.local/bin/rogue"
    else
        log_step "Copying rogue script..."
        rsync -avh "$ROGUE_DIR/rogue" "$HOME/.local/bin/rogue" > /dev/null 2>&1
        chmod +x "$HOME/.local/bin/rogue"
    fi

    log_step "Installing modules..."
    rsync -avh "$ROGUE_DIR/modules/" "$HOME/.config/rogue/modules/" > /dev/null 2>&1

    if [ -d "$ROGUE_DIR/RogueTemplates" ]; then
        log_step "Copying templates..."
        rsync -avh "$ROGUE_DIR/RogueTemplates/" "$HOME/.config/rogue/templates/" > /dev/null 2>&1
    else
        log_step "Templates source not found — skipping."
    fi

    if [ -f "$ROGUE_DIR/rp.list" ]; then
        log_step "Copying rp.list..."
        rsync -avh "$ROGUE_DIR/rp.list" "$HOME/.config/rogue/rp.list" > /dev/null 2>&1
    else
        log_step "rp.list source not found — skipping."
    fi

    if [ -f "$ROGUE_DIR/RogueConfig" ]; then
        log_step "Copying RogueConfig..."
        rsync -avh "$ROGUE_DIR/RogueConfig" "$HOME/.config/rogue/config" > /dev/null 2>&1
    else
        log_step "RogueConfig source not found — skipping."
    fi

    log_step "Generating rogueConf.json..."
    cat > "$HOME/.config/rogue/rogueConf.json" << JSONEOF
{
  "projects_dir": "/mnt/sda4/projects",
  "templates_dir": "~/.config/rogue/templates",
  "modules_dir": "~/.config/rogue/modules",
  "local_projects_list": "~/.config/rogue/rp.list",
  "config_file": "~/.config/rogue/config",
  "default_remote": "github",
  "terminal_app": "alacritty",
  "file_manager": "dolphin",
  "rogue_script": "~/.local/bin/rogue"
}
JSONEOF

    declare -a shell_configs=()

    if command -v bash &> /dev/null && [ -f "$HOME/.bashrc" ]; then
        shell_configs+=("bash|$HOME/.bashrc")
    fi
    if command -v zsh &> /dev/null && [ -f "$HOME/.zshrc" ]; then
        shell_configs+=("zsh|$HOME/.zshrc")
    fi
    if command -v fish &> /dev/null && [ -f "$HOME/.config/fish/config.fish" ]; then
        shell_configs+=("fish|$HOME/.config/fish/config.fish")
    fi

    if [ ${#shell_configs[@]} -eq 0 ]; then
        log_error "Could not detect any shell config files."
        echo ""
        log_info "Add this manually to your shell configuration:"
        echo -e "  ${BOLD}rogue() { source ~/.local/bin/rogue \"\$@\"; }${RESET}"
        return 1
    fi

    local added_shells=()
    for entry in "${shell_configs[@]}"; do
        local shell_type="${entry%%|*}"
        local rc_file="${entry#*|}"

        if grep -q "rogue()" "$rc_file" 2>/dev/null || grep -q "function rogue" "$rc_file" 2>/dev/null; then
            log_step "Rogue function already exists in $rc_file. Skipping."
            added_shells+=("$shell_type")
        else
            log_step "Adding rogue function to $rc_file..."
            if [ "$shell_type" = "fish" ]; then
                cat >> "$rc_file" << 'FISHEOF'

# RoguePM - Project Manager
function rogue
    bash ~/.local/bin/rogue $argv
    if test -f /tmp/.rogue_cd
        cd (cat /tmp/.rogue_cd)
        rm /tmp/.rogue_cd
    end
end
FISHEOF
            else
                cat >> "$rc_file" << 'BASHEOF'

# RoguePM - Project Manager
rogue() {
    source ~/.local/bin/rogue "$@"
}
BASHEOF
            fi
            added_shells+=("$shell_type")
        fi
    done

    local shell_list=""
    for s in "${added_shells[@]}"; do
        shell_list="${shell_list}${shell_list:+, }$s"
    done

    cat > "$HOME/.roguerc" << EOF
# RoguePM - Installed via 'rogue setup'
# Settings here override rogueConf.json values.
ROGUE_CONFIG="$HOME/.config/rogue/rogueConf.json"
PROJECTS_DIR="/mnt/sda4/projects"
TEMPLATES_DIR="$HOME/.config/rogue/templates"
LOCAL_PROJECTS_LIST="$HOME/.config/rogue/rp.list"
DEFAULT_REMOTE="github"
TERMINAL_APP="alacritty"
FILE_MANAGER="dolphin"
EOF

    local install_type="copy"
    [ "$sym" = "true" ] && install_type="symlink"

    log_success "RoguePM has been installed successfully!"
    echo ""
    log_info "Installation summary:"
    echo -e "  ${BOLD}Script:${RESET}     ~/.local/bin/rogue ($install_type)"
    echo -e "  ${BOLD}Modules:${RESET}    ~/.config/rogue/modules/"
    echo -e "  ${BOLD}Config:${RESET}     ~/.config/rogue/rogueConf.json"
    echo -e "  ${BOLD}Templates:${RESET}  ~/.config/rogue/templates/"
    echo -e "  ${BOLD}rp.list:${RESET}    ~/.config/rogue/rp.list"
    echo -e "  ${BOLD}Shells:${RESET}     $shell_list"
    echo ""

    echo -e "\n────────────────────────────────────────────"
    echo -e "${ROGUE_RED_ITALIC}[Rogue]${RESET} ${BOLD_ITALIC_UNDERLINE}Dependency Check${RESET}\n"

    local deps_ok=true
    local dep_warnings=""

    while IFS='|' read -r cmd label msg; do
        if ! command -v "$cmd" &> /dev/null; then
            deps_ok=false
            dep_warnings+="  ${YELLOW}✗${RESET} $label — not found. $msg\n"
        fi
    done << DEPS
git|git|Core VCS needed for all project operations.
gh|GitHub CLI (gh)|GitHub remotes will not work in new, addRemote.
glab|GitLab CLI (glab)|GitLab remotes will not work in new, addRemote.
fzf|fzf|Template picker, open menu, and session subdir selection won't work.
jq|jq|JSON config (rogueConf.json) will not be read.
socat|socat|Daemon communication (rogue daemon) will not work.
tree|tree|Directory tree display after template creation will be skipped.
rsync|rsync|File copying during setup may fall back to cp.
DEPS

    if [ "$deps_ok" = false ]; then
        echo -e "$dep_warnings"
        log_info "Install missing tools with your package manager (e.g. apt install <package>)."
    else
        log_success "All dependencies found."
    fi
    echo ""
    log_info "Restart your terminal or source your shell config to use 'rogue'."
}

# ==========================================
# MAIN DISPATCHER
# ==========================================

main() {
    rm -f /tmp/.rogue_cd
    print_banner

    if [[ $# -eq 0 ]]; then
        print_help
        return 1
    fi

    local command="$1"
    shift

    case "$command" in
        new) cmd_new "$@" ;;

        template) cmd_template "$@" ;;
        
        snapshot)
            [[ $# -gt 0 ]] && { log_error "'snapshot' takes no arguments."; return 1; }
            cmd_snapshot ;;

        addRemote) cmd_addRemote "$@" ;;

        setPat)
            [[ $# -gt 0 ]] && { log_error "'setPat' takes no arguments."; return 1; }
            cmd_setPat ;;
                
        setup) cmd_setup "$@" ;;

        update) cmd_update "$@" ;;

        list) cmd_list "$@" ;;

        open) cmd_open "$@" ;;

        daemon) cmd_daemon "$@" ;;

        --version|-v) log_info "RoguePM v${VERSION}" ;;
        --help|-h|help) print_help ;;

        *)
            log_error "Unknown command: $command"
            print_help
            return 1 ;;
    esac
}

main "$@"
